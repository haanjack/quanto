# Development Docker image for AMD ROCm quantization
# Build: docker build -f docker/Dockerfile.rocm.dev -t quanto:rocm-dev .
# Run: docker run --device=/dev/kfd --device=/dev/dri --group-add video \
#          -v ~/models:/models -v $(pwd):/workspace -w /workspace quanto:rocm-dev

FROM rocm/pytorch:latest

LABEL maintainer="haanjack"
LABEL description="Development Docker image for AMD ROCm LLM quantization"
LABEL version="dev"

ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git build-essential \
    && rm -rf /var/lib/apt/lists/*

# Upgrade pip
RUN pip install --upgrade pip setuptools wheel

# Install core Python dependencies
RUN pip install \
    transformers>=4.40.0 \
    accelerate>=0.30.0 \
    datasets>=2.18.0 \
    safetensors>=0.4.0 \
    sentencepiece>=0.2.0 \
    tiktoken>=0.6.0 \
    zstandard>=0.22.0

# Install quantization dependencies
RUN pip install \
    onnx>=1.16.0 \
    onnxslim>=0.1.0 \
    onnxscript>=0.1.0

# Install evaluation dependencies
RUN pip install \
    nltk>=3.8.0 \
    lm-eval>=0.4.0 \
    evaluate>=0.4.0 \
    scikit-learn>=1.4.0

# Install utilities
RUN pip install \
    tqdm>=4.66.0 \
    rich>=13.0.0 \
    pyyaml>=6.0 \
    pydantic>=2.0.0

# Set ROCm architecture for kernel compilation
ENV PYTORCH_ROCM_ARCH="gfx1030;gfx1036;gfx1100;gfx1101"

# Install Quark (for development, mount locally instead)
# RUN pip install git+https://github.com/amd/Quark.git

WORKDIR /workspace

# For development: mount source with -v $(pwd):/workspace
CMD ["bash"]
